# Private Cloud Gateway — local development Caddyfile
#
# Uses localtest.me: a real domain with public wildcard DNS (*.localtest.me → 127.0.0.1).
# No hosts file changes needed. Works in all browsers. Cookie domain sharing works correctly
# because browsers treat localtest.me as a normal registrable domain.
#
# Production Caddyfile (with HTTPS + wildcard certs) will be added in Milestone 5.

{
	auto_https off
	admin localhost:2019
	log {
		level INFO
	}
}

# ── Dashboard and authentication ──────────────────────────────────────────────

http://home.localtest.me {
	reverse_proxy core:8080
}

# ── Protected app routes ──────────────────────────────────────────────────────
# Pattern: forward_auth verifies the session, then proxy to the app container.
# On 200 → Caddy proxies. On non-200 → Go Core returns 302 to the login page.

http://files.localtest.me {
	forward_auth core:8080 {
		uri /api/auth/verify
		copy_headers X-Auth-User-ID
	}

	reverse_proxy whoami:80
}

# Add more protected subdomains following the same pattern above.
# Example for a future PDF app:
#
# http://pdf.localtest.me {
#     forward_auth core:8080 {
#         uri /api/auth/verify
#         copy_headers X-Auth-User-ID
#     }
#     reverse_proxy stirling-pdf:8080
# }
