# Private Cloud Gateway — local development environment
#
# Copy this file to .env before running locally.
#   cp .env.example .env
#
# Never commit .env. It is in .gitignore.
# The CLOUD_CORE_* prefix refers to the internal Go service (Cloud Core engine).

# ── Core ──────────────────────────────────────────────────────────────────────

CLOUD_CORE_ENV=development
CLOUD_CORE_PORT=8080
CLOUD_CORE_DOMAIN=localhost

# ── Database ──────────────────────────────────────────────────────────────────

CLOUD_CORE_DATABASE_PATH=./data/cloud-core.db

# ── Session ───────────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Never reuse this value in production.
# Generate a safe secret: openssl rand -hex 32

CLOUD_CORE_SESSION_SECRET=change-me-dev-only-generate-with-openssl-rand

# Session lifetime in minutes (default: 480 = 8 hours)
CLOUD_CORE_SESSION_TTL_MINUTES=480

# ── Admin bootstrap ───────────────────────────────────────────────────────────
# Used only on first startup to create the initial admin account.
# Remove or leave blank after first login.

CLOUD_CORE_BOOTSTRAP_EMAIL=admin@example.com
CLOUD_CORE_BOOTSTRAP_PASSWORD=change-me-on-first-login

# ── Backup ────────────────────────────────────────────────────────────────────

CLOUD_CORE_BACKUP_DIR=./backups

# Backup encryption passphrase — leave blank to disable encryption (not recommended)
CLOUD_CORE_BACKUP_PASSPHRASE=

# ── Caddy ─────────────────────────────────────────────────────────────────────
# The Caddy admin API port must never be exposed publicly.

CADDY_ADMIN_PORT=2019

# ── Docker ────────────────────────────────────────────────────────────────────

DOCKER_NETWORK=cloud_core_private
